{
  "name": "pnife",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:main": "tsc -p tsconfig.main.json",
    "build:all": "vite build && tsc -p tsconfig.main.json",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:renderer": "vite",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json -w\" \"wait-on tcp:5173 dist/main/main.js dist/preload/preload.js && electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.main.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^3.0.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "react": "^19.0.0",
    "sql.js": "^1.13.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@types/sql.js": "^1.4.9",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  }
}
